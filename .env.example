# Copy to ".env" and set your secret values. ".env" is gitignored.
#
# EmDash CLI (remote): https://docs.emdashcms.com/
EMDASH_TOKEN=

# Optional: override origin for scripts/emdash-remote.sh (custom domain or workers.dev)
# EMDASH_REMOTE_ORIGIN=https://emdash.denshochan.com

# Cloudflare Zero Trust (Access) service token — required for CLI when the app is behind Access
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Or set EMDASH_HEADERS with a real newline between the two header lines (not the two-char sequence \n).
